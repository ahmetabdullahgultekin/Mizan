# ==============================================================================
# Mizan Core Engine - PRODUCTION Environment Configuration
# ==============================================================================
# IMPORTANT: Fill ALL values below before deploying. Do NOT use defaults.
# This file documents every required setting for a production deployment.

# ==============================================================================
# Database (REQUIRED)
# ==============================================================================
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# ==============================================================================
# Redis (REQUIRED)
# ==============================================================================
REDIS_URL=redis://HOST:6379/0
REDIS_POOL_SIZE=20
CACHE_TTL=3600

# ==============================================================================
# API Settings
# ==============================================================================
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=WARNING
DEBUG=false

# ==============================================================================
# Security (REQUIRED - change ALL of these)
# ==============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_GENERATE_A_STRONG_KEY

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["https://mizan.app","https://www.mizan.app"]

# API key for library mutation endpoints (generate a strong random value)
API_KEY=CHANGE_ME_GENERATE_A_STRONG_KEY

# ==============================================================================
# Data Integrity
# ==============================================================================
EXPECTED_QURAN_CHECKSUM=
FAIL_ON_INTEGRITY_ERROR=true

# ==============================================================================
# Embedding Configuration
# ==============================================================================
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_DIMENSION=768
EMBEDDING_BATCH_SIZE=32
# Only required if EMBEDDING_PROVIDER=gemini
GEMINI_API_KEY=

# ==============================================================================
# Observability (RECOMMENDED)
# ==============================================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
