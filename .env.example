# ==============================================================================
# Mizan Core Engine - Environment Configuration
# ==============================================================================
# Copy this file to .env and update values for your environment

# Database Configuration
# ------------------------------------------------------------------------------
# Local development (Docker):
# DATABASE_URL=postgresql+asyncpg://mizan:mizan@localhost:5432/mizan
#
# Supabase (Production - Railway deployment):
# Get your connection string from: Supabase Dashboard > Project Settings > Database > Connection string > URI
# Replace [YOUR-PASSWORD] with your database password
# Example: postgresql+asyncpg://postgres.xxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Redis Cache Configuration
# ------------------------------------------------------------------------------
# Local development:
# REDIS_URL=redis://localhost:6379/0
#
# Railway Redis (Production):
# Railway automatically provides REDIS_URL when you add Redis service
REDIS_URL=redis://localhost:6379/0

# API Settings
# ------------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
DEBUG=false

# Security
# ------------------------------------------------------------------------------
# IMPORTANT: Change this in production!
SECRET_KEY=your-secret-key-here-change-in-production

# CORS allowed origins — comma-separated list of allowed frontend origins.
# Local dev: http://localhost:3000
# Production example: https://mizan.app,https://www.mizan.app
ALLOWED_ORIGINS=["http://localhost:3000"]

# API key for library mutation endpoints (POST/DELETE).
# Leave empty to disable auth (local dev only). Set a strong random value in production.
# Frontend must send: X-API-Key: <value>
API_KEY=

# Integrity Verification
# ------------------------------------------------------------------------------
# SHA256 checksum of the complete Quran text (computed on first ingestion)
EXPECTED_QURAN_CHECKSUM=
# If true, the system will halt on any integrity violation
FAIL_ON_INTEGRITY_ERROR=true

# Data Sources
# ------------------------------------------------------------------------------
# Path to Tanzil XML files
TANZIL_DATA_PATH=./data/tanzil
# Path to MASAQ dataset
MASAQ_DATA_PATH=./data/masaq

# Performance Settings
# ------------------------------------------------------------------------------
# Database connection pool size
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
# Redis connection pool size
REDIS_POOL_SIZE=10
# Cache TTL in seconds (default: 1 hour)
CACHE_TTL=3600

# Experimental Features (Tier 4-5)
# ------------------------------------------------------------------------------
# Enable semantic analysis features (Library + Semantic Search)
ENABLE_SEMANTIC_ANALYSIS=true
# Enable structural analysis research tools
ENABLE_STRUCTURAL_TOOLS=false

# Embedding Configuration (Tier 4 - Semantic Search)
# ------------------------------------------------------------------------------
# Provider: 'local' (offline, recommended) or 'gemini' (Google API)
EMBEDDING_PROVIDER=local
# Local model: HuggingFace model name (downloads ~280MB on first use)
# Gemini model: 'gemini-embedding-2-preview' or 'text-embedding-004'
EMBEDDING_MODEL=intfloat/multilingual-e5-base
# Dimension must match model output (768 for e5-base, gemini-embedding-2)
EMBEDDING_DIMENSION=768
# Batch size for bulk embedding (reduce if you hit OOM errors)
EMBEDDING_BATCH_SIZE=32
# Google Gemini API key (only required when EMBEDDING_PROVIDER=gemini)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
